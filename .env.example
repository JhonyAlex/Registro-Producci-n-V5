NODE_ENV=production
PORT=3000

# Replace db with your Dokploy PostgreSQL service name
DATABASE_URL=postgresql://postgres:change_me@db:5432/pigmea

# Generate a long random string (at least 32 chars)
JWT_SECRET=change_this_to_a_long_random_secret

# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=30

# Optional: only if Gemini features are used
GEMINI_API_KEY=
